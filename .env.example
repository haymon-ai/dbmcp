# Database backend (required): mysql, mariadb, postgres, sqlite
DB_BACKEND=mysql

# Database connection (all optional — sensible defaults per backend)
# DB_HOST=localhost        # default: localhost
# DB_PORT=3306             # default: 3306 (MySQL/MariaDB), 5432 (PostgreSQL)
# DB_USER=root             # default: root (MySQL/MariaDB), postgres (PostgreSQL)
# DB_PASSWORD=secret
# DB_NAME=mydb
# DB_CHARSET=utf8mb4       # MySQL/MariaDB only

# SSL/TLS
# DB_SSL=false
# DB_SSL_CA=/path/to/ca.pem
# DB_SSL_CERT=/path/to/cert.pem
# DB_SSL_KEY=/path/to/key.pem
# DB_SSL_VERIFY_CERT=true

# Server behavior
# MCP_READ_ONLY=true       # default: true — blocks write queries
# MCP_MAX_POOL_SIZE=10     # default: 10

# Logging
# LOG_LEVEL=info           # trace, debug, info, warn, error
# LOG_FILE=logs/mcp_server.log
