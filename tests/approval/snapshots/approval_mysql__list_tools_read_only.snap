        },
        "database": {
          "default": null,
          "description": "Database to list procedures from. Defaults to the active database.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "title": "ListProceduresRequest",
      "type": "object"
    },
    "outputSchema": {
