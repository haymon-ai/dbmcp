  },
  {
    "name": "listViews",
    "title": "List Views",
    "description": "List all views in a database.\n\n<usecase>\nUse when:\n- Exploring a database to find defined views alongside tables\n- Verifying a view exists before querying it\n- The user asks what views are in a database\n</usecase>\n\n<examples>\n✓ \"What views are in the mydb database?\" → listViews(database=\"mydb\")\n✓ \"Does an active_users view exist?\" → listViews to check\n✗ \"Show me the columns of a view\" → use listTables with detailed=true instead\n✗ \"List materialized views\" → use listMaterializedViews (PostgreSQL only)\n</examples>\n\n<what_it_returns>\nA sorted JSON array of view name strings.\n</what_it_returns>\n\n<pagination>\nPaginated. Pass the prior response's `nextCursor` as `cursor` to fetch the next page.\n</pagination>",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Request for the `listViews` tool.",
      "properties": {
        "cursor": {
          "default": null,
          "description": "Opaque cursor from a prior response's `nextCursor`; omit for the first page.",
          "type": [
            "string",
            "null"
          ]
        },
        "database": {
          "default": null,
          "description": "Database to list views from. Defaults to the active database.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "title": "ListViewsRequest",
      "type": "object"
    },
    "outputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Response for the `listViews` tool.",
      "properties": {
        "nextCursor": {
          "description": "Opaque cursor pointing to the next page. Absent when this is the final page.",
          "type": [
            "string",
